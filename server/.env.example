# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/messaging_platform

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# Presigned URL expiry in seconds (default: 1 hour)
S3_PRESIGNED_URL_EXPIRY=3600

# AI (Gemini 2.5 Flash via platform gateway) — injected automatically in managed environments
# For local development, set this to your INTEGRATIONS_API_KEY value
INTEGRATIONS_API_KEY=your_integrations_api_key_here
