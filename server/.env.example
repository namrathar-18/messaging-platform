# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/messaging_platform

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
# Optional comma-separated allowlist for deployed frontend URLs and preview URLs
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth - planned for later
# GOOGLE_CLIENT_ID=your_google_oauth_client_id_here


# AI (Gemini 2.5 Flash via platform gateway) — injected automatically in managed environments
# For local development, set this to your INTEGRATIONS_API_KEY value
INTEGRATIONS_API_KEY=your_integrations_api_key_here
